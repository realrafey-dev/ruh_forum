<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="nav-logo" aria-label="RUH Forum - Home">
        <img src="/images/RUH_Forum_Logo.png" alt="RUH Forum" class="nav-logo-img" width="150" height="150" loading="lazy">
      </a>
      <div class="nav-overlay" id="navOverlay"></div>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <i class="fas fa-bars"></i>
      </button>
      <ul class="nav-menu" id="navMenu">
        <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="/donate"><i class="fas fa-hand-holding-heart"></i> Donate</a></li>
        <li><a href="/trusts"><i class="fas fa-shield-alt"></i> Trusts</a></li>
        <li><a href="/campaigns"><i class="fas fa-bullhorn"></i> Campaigns</a></li>
        <li><a href="/zakat"><i class="fas fa-calculator"></i> Zakat</a></li>
        <% if (user) { %>
          <li><a href="/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
          <li><a href="/change-password"><i class="fas fa-key"></i> Password</a></li>
          <% if (user.is_admin) { %>
            <li><a href="/admin"><i class="fas fa-shield-alt" style="color:#ff6b6b;"></i> Admin</a></li>
          <% } %>
          <li><a href="/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        <% } else { %>
          <li><a href="/login" class="btn-login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
          <li><a href="/register" class="btn-register"><i class="fas fa-user-plus"></i> Register</a></li>
        <% } %>
      </ul>
    </div>
  </nav>
  <div class="flash-container">
    <% if (success && success.length > 0) { %>
      <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (info && info.length > 0) { %>
      <div class="flash flash-info"><i class="fas fa-info-circle"></i> <%= info %></div>
    <% } %>
  </div>
