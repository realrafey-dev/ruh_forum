<%- include('partials/header') %>
<section class="detail-section">
  <div class="container">
    <div class="detail-card">
      <div class="detail-header">
        <i class="fas fa-shield-alt"></i>
        <h1><%= trust.title %></h1>
        <p class="relation-badge"><i class="fas fa-heart"></i> <%= trust.relation %></p>
        <p class="creator-name">Created by: <%= trust.creator_name %></p>
      </div>

      <% if (trust.photo) { %>
        <img src="<%= trust.photo %>" alt="<%= trust.title %>" class="detail-photo">
      <% } %>

      <p class="detail-desc"><%= trust.description || 'No description provided.' %></p>

      <div class="progress-section">
        <div class="progress-bar large">
          <div class="progress-fill" style="width: <%= Math.min(100, (trust.raised_amount / (trust.target_amount || 1)) * 100) %>%"></div>
        </div>
        <p class="progress-text">
          <strong>Rs. <%= Number(trust.raised_amount).toLocaleString() %></strong> raised
          <% if (trust.target_amount > 0) { %>
            of Rs. <%= Number(trust.target_amount).toLocaleString() %> target
          <% } %>
        </p>
      </div>

      <div class="bank-info-card" style="margin:20px 0;">
        <h3><i class="fas fa-university"></i> Transfer to Bank Account</h3>
        <div class="bank-details">
          <p><strong>Bank:</strong> [Your Bank Name]</p>
          <p><strong>Account:</strong> [Account Number]</p>
          <p><strong>IBAN:</strong> [IBAN Number]</p>
          <p><strong>Title:</strong> RUH Forum</p>
        </div>
        <p class="bank-note">After transfer, upload screenshot below</p>
      </div>

      <div class="donate-section-inline">
        <h3>Donate to this Trust</h3>
        <form action="/trusts/<%= trust.id %>/donate" method="POST" enctype="multipart/form-data" class="donate-form">
          <% if (!user) { %>
            <div class="form-row">
              <div class="form-group">
                <label>Name *</label>
                <input type="text" name="name" required>
              </div>
              <div class="form-group">
                <label>Email *</label>
                <input type="email" name="email" required>
              </div>
            </div>
            <div class="form-group">
              <label>Phone</label>
              <input type="tel" name="phone">
            </div>
          <% } else { %>
            <input type="hidden" name="name" value="<%= user.full_name %>">
            <input type="hidden" name="email" value="<%= user.email %>">
          <% } %>
          <div class="form-group">
            <label>Amount *</label>
            <input type="number" name="amount" required min="1">
          </div>
          <div class="form-group">
            <label>Message (Optional)</label>
            <textarea name="message" rows="2"></textarea>
          </div>
          <div class="form-group">
            <label>Payment Screenshot</label>
            <input type="file" name="screenshot" accept="image/*">
          </div>
          <div class="form-checkboxes">
            <label class="checkbox-label">
              <input type="checkbox" name="is_anonymous">
              <span>Donate Anonymously (name hide karein)</span>
            </label>
          </div>
          <button type="submit" class="btn btn-primary btn-full">Donate</button>
        </form>
      </div>

      <% if (donations && donations.length > 0) { %>
        <div class="donors-section">
          <h3>Donors</h3>
          <div class="donors-list">
            <% donations.forEach(function(d) { %>
              <div class="donor-item">
                <i class="fas fa-user-circle"></i>
                <div>
                  <strong><%= d.is_anonymous ? 'Anonymous' : d.name %></strong>
                  <p>Rs. <%= Number(d.amount).toLocaleString() %> - <%= new Date(d.created_at).toLocaleDateString() %></p>
                  <% if (d.message) { %><p class="donor-message">"<%= d.message %>"</p><% } %>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
