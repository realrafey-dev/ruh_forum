<%- include('../partials/header') %>
<section class="dashboard">
  <div class="container">
    <div class="welcome-banner" style="background: linear-gradient(135deg, #8b0000, #5c0000);">
      <h1><i class="fas fa-shield-alt"></i> Admin Panel</h1>
      <p>Manage donations, users, and trusts</p>
    </div>

    <div class="dashboard-stats">
      <div class="dash-stat-card">
        <i class="fas fa-donate"></i>
        <h3><%= stats.donations %></h3>
        <p>Total Donations</p>
      </div>
      <div class="dash-stat-card">
        <i class="fas fa-rupee-sign"></i>
        <h3>Rs. <%= Number(stats.amount).toLocaleString() %></h3>
        <p>Total Amount</p>
      </div>
      <div class="dash-stat-card">
        <i class="fas fa-users"></i>
        <h3><%= stats.users %></h3>
        <p>Users</p>
      </div>
      <div class="dash-stat-card">
        <i class="fas fa-shield-alt"></i>
        <h3><%= stats.trusts %></h3>
        <p>Trusts</p>
      </div>
    </div>

    <div class="quick-actions">
      <a href="/admin/donations" class="action-card" style="border: 2px solid #8b0000;">
        <i class="fas fa-check-double"></i>
        <span>Verify Donations</span>
      </a>
      <a href="/donate" class="action-card">
        <i class="fas fa-plus-circle"></i>
        <span>Add Donation</span>
      </a>
      <a href="/trusts" class="action-card">
        <i class="fas fa-shield-alt"></i>
        <span>View Trusts</span>
      </a>
      <a href="/admin/campaigns/create" class="action-card" style="border: 2px solid #1a5c2a;">
        <i class="fas fa-plus-circle"></i>
        <span>Create Campaign</span>
      </a>
      <a href="/campaigns" class="action-card">
        <i class="fas fa-bullhorn"></i>
        <span>Campaigns</span>
      </a>
    </div>

    <div class="admin-section" style="margin-top:30px;background:white;padding:25px;border-radius:12px;">
      <h3><i class="fas fa-user-shield"></i> Manage Admins</h3>
      <form action="/admin/admins" method="POST" style="display:flex;gap:10px;margin:15px 0;flex-wrap:wrap;">
        <input type="email" name="email" required placeholder="Enter user email" style="flex:1;min-width:200px;padding:10px 15px;border:2px solid #e0d6c8;border-radius:8px;">
        <button type="submit" class="btn btn-primary" style="padding:10px 20px;"><i class="fas fa-plus"></i> Add Admin</button>
      </form>
      <% if (adminList && adminList.length > 0) { %>
        <table style="width:100%;border-collapse:collapse;margin-top:10px;">
          <thead>
            <tr style="background:#f5f0e8;">
              <th style="padding:10px;text-align:left;">Name</th>
              <th style="padding:10px;text-align:left;">Email</th>
              <th style="padding:10px;text-align:left;">Since</th>
            </tr>
          </thead>
          <tbody>
            <% adminList.forEach(function(a) { %>
              <tr style="border-bottom:1px solid #e0d6c8;">
                <td style="padding:10px;"><%= a.full_name %></td>
                <td style="padding:10px;"><%= a.email %></td>
                <td style="padding:10px;"><%= new Date(a.added_on).toLocaleDateString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="empty-state">No admins found.</p>
      <% } %>
    </div>

    <div class="recent-section">
      <h2>Recent Donations</h2>
      <% if (recentDonations && recentDonations.length > 0) { %>
        <div class="donation-table-wrapper">
          <table class="donation-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Amount</th>
                <th>Type</th>
                <th>Status</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% recentDonations.forEach(function(d) { %>
                <tr>
                  <td>#<%= d.id %></td>
                  <td><%= d.name %></td>
                  <td>Rs. <%= Number(d.amount).toLocaleString() %></td>
                  <td><%= d.trust_title || d.campaign_id ? 'Campaign' : d.type %></td>
                  <td><span class="status-badge status-<%= d.status %>"><%= d.status %></span></td>
                  <td><%= new Date(d.created_at).toLocaleDateString() %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="empty-state">No donations yet.</p>
      <% } %>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
