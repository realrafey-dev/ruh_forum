<%- include('../partials/header') %>
<section class="dashboard">
  <div class="container">
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center;">
      <h1><i class="fas fa-list"></i> All Donations</h1>
      <a href="/admin" class="btn btn-small"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <% if (!donations || donations.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-inbox"></i>
        <h3>No Donations</h3>
      </div>
    <% } else { %>
      <div class="recent-section">
        <div class="donation-table-wrapper">
          <table class="donation-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Amount</th>
                <th>Type</th>
                <th>For</th>
                <th>Screenshot</th>
                <th>Status</th>
                <th>Date</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% donations.forEach(function(d) { %>
                <tr>
                  <td>#<%= d.id %></td>
                  <td><%= d.name %></td>
                  <td><%= d.email %></td>
                  <td><strong>Rs. <%= Number(d.amount).toLocaleString() %></strong></td>
                  <td><%= d.type %></td>
                  <td><%= d.trust_title || d.campaign_title || '-' %></td>
                  <td>
                    <% if (d.screenshot) { %>
                      <a href="<%= d.screenshot %>" target="_blank" class="btn btn-small"><i class="fas fa-image"></i> View</a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td><span class="status-badge status-<%= d.status %>"><%= d.status %></span></td>
                  <td><%= new Date(d.created_at).toLocaleDateString() %></td>
                  <td>
                    <% if (d.status === 'pending') { %>
                      <form action="/admin/donations/<%= d.id %>/verified" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-small" style="background:#27ae60;color:white;padding:5px 10px;font-size:12px;">
                          <i class="fas fa-check"></i> Approve
                        </button>
                      </form>
                      <form action="/admin/donations/<%= d.id %>/rejected" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-small" style="background:#c0392b;color:white;padding:5px 10px;font-size:12px;">
                          <i class="fas fa-times"></i> Reject
                        </button>
                      </form>
                    <% } else { %>
                      <span style="color:#999;font-size:12px;">Done</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</section>
<%- include('../partials/footer') %>
