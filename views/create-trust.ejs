<%- include('partials/header') %>
<section class="auth-section">
  <div class="container">
    <div class="auth-card">
      <div class="auth-header">
        <i class="fas fa-shield-alt"></i>
        <h2>Create a Trust</h2>
        <p>In the name of Allah, the Most Gracious, the Most Merciful</p>
      </div>
      <form action="/trusts/create" method="POST" enctype="multipart/form-data" class="auth-form">
        <div class="form-group">
          <label><i class="fas fa-tag"></i> Trust Title *</label>
          <input type="text" name="title" required placeholder="e.g. Sadaqah for My Mother's Soul">
          <p class="form-note">Example: "Sadaqah-e-Jariyah for Marhooma Ammi Jan"</p>
        </div>
        <div class="form-group">
          <label><i class="fas fa-heart"></i> Relation *</label>
          <input type="text" name="relation" required placeholder="e.g. My Mother, My Father, My Child">
        </div>
        <div class="form-group">
          <label><i class="fas fa-align-left"></i> Description</label>
          <textarea name="description" rows="3" placeholder="Tell people about this trust..."></textarea>
        </div>
        <div class="form-group">
          <label><i class="fas fa-rupee-sign"></i> Target Amount (Optional)</label>
          <input type="number" name="target_amount" min="0" step="0.01" placeholder="Target fundraising amount">
        </div>
        <div class="form-group">
          <label><i class="fas fa-image"></i> Photo</label>
          <input type="file" name="photo" accept="image/*" class="file-input">
          <p class="form-note">Upload a photo (optional)</p>
        </div>
        <button type="submit" class="btn btn-primary btn-full">
          <i class="fas fa-check-circle"></i> Create Trust
        </button>
      </form>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
